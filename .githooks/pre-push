#!/bin/sh
# Pre-push hook: verify the full Cloudflare deploy pipeline passes locally.
# Prevents pushing broken builds that waste CF build minutes and time.
#
# Install: git config core.hooksPath .githooks
# Skip once: git push --no-verify

set -e

echo "==> Running web tests..."
bun run --filter @kuruma/web test

echo "==> Building Next.js..."
cd packages/web
bun run build

echo "==> Building Cloudflare worker..."
bun run build:worker

echo "==> All checks passed. Pushing."
