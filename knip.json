{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "workspaces": {
    ".": {
      "entry": ["scripts/db-verify.ts"],
      "ignore": [
        "drizzle/**",
        ".wrangler/**",
        "packages/*/.wrangler/**",
        "packages/*/.open-next/**",
        "packages/*/.next/**"
      ],
      "ignoreDependencies": ["drizzle-kit"],
      "ignoreBinaries": ["wrangler", "vitest", "tsc", "drizzle-kit"]
    },
    "packages/shared": {
      "entry": [
        "src/index.ts",
        "src/db/index.ts",
        "src/db/schema.ts",
        "src/db/seed.ts",
        "src/validators/**/*.ts",
        "src/types/**/*.ts",
        "src/lib/**/*.ts"
      ],
      "project": ["src/**/*.ts", "!src/**/*.d.ts"],
      "ignore": ["postcss.config.mjs"],
      "ignoreBinaries": ["vitest", "tsc"]
    },
    "packages/api": {
      "entry": [
        "src/index.ts",
        "vitest.config.ts",
        "vitest.integration.config.ts",
        "tests/**/*.test.ts",
        "tests/integration/**/*.ts",
        "tests/helpers/**/*.ts"
      ],
      "project": ["src/**/*.ts", "tests/**/*.ts"],
      "ignore": [".wrangler/**", "wrangler.jsonc"],
      "ignoreDependencies": ["@cloudflare/workers-types", "wrangler"],
      "ignoreBinaries": ["wrangler", "vitest", "tsc"]
    },
    "packages/web": {
      "entry": [
        "src/app/**/page.tsx",
        "src/app/**/layout.tsx",
        "src/app/**/error.tsx",
        "src/app/**/not-found.tsx",
        "src/app/**/loading.tsx",
        "src/app/**/template.tsx",
        "src/app/**/default.tsx",
        "src/app/**/route.ts",
        "src/app/**/global-error.tsx",
        "src/middleware.ts",
        "src/i18n/request.ts",
        "src/i18n/routing.ts",
        "src/auth.ts",
        "src/auth.config.ts",
        "next.config.ts",
        "open-next.config.ts",
        "middleware.ts",
        "tests/**/*.test.ts",
        "tests/**/*.test.tsx"
      ],
      "project": ["src/**/*.{ts,tsx}", "tests/**/*.{ts,tsx}"],
      "ignore": [".next/**", ".open-next/**", "src/components/ui/**"],
      "ignoreDependencies": ["tailwindcss", "@tailwindcss/postcss", "postcss"],
      "ignoreBinaries": ["next", "vitest", "tsc"]
    }
  }
}
